# ============================================================================
# agent_mem — environment variables (copy to .env and edit)
# All variables here are read by either the Go service or the Python service.
# ============================================================================

# ----- Go service (cmd/api on :3111, viewer on :3113) -----
PORT=3111
VIEWER_PORT=3113
LOG_LEVEL=info

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=medha
POSTGRES_PASSWORD=medha-password
POSTGRES_DB=medha
POSTGRES_SSLMODE=disable

# Neo4j (optional — see ADR-0003; service runs in degraded mode without it)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_ENABLED=false

# Async queue (see ADR-0001) — backend = rabbitmq | memory
QUEUE_BACKEND=memory
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Python service URL (Go → Python for extraction/compression/summary/embed)
PYTHON_SERVICE_URL=http://localhost:5000

# Feature flags
AGENTMEMORY_AUTO_COMPRESS=false
AGENTMEMORY_SLOTS=false
AGENTMEMORY_REFLECT=false
CONSOLIDATION_ENABLED=true
LESSON_DECAY_ENABLED=true

# Decay tuning (ADR-0002 — config-driven)
DECAY_RATE_PER_DAY=0.95
DECAY_EVICTION_THRESHOLD=0.1
DECAY_REVIEW_LOW=0.1
DECAY_REVIEW_HIGH=0.3

# Security (Bearer token on mutating endpoints)
AGENTMEMORY_SECRET=replace-me-with-random

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=agent-mem-go

# ----- Python service (FastAPI on :5000) -----
PY_PORT=5000
PY_LOG_LEVEL=info

# Bifrost gateway (required — service will not start without BIFROST_URL)
BIFROST_URL=http://192.168.2.196:8080
BIFROST_API_KEY=

# LLM models (OpenRouter vendor/model format, or bare name)
# Examples: anthropic/claude-3-5-haiku, openai/gpt-4o-mini, meta-llama/llama-3.1-8b-instruct
LLM_MODEL=

# Per-stage overrides (optional — all fall back to LLM_MODEL when unset)
COMPRESS_MODEL=
SUMMARIZE_MODEL=
EXTRACT_MODEL=

# Embedding model (optional — if unset, local hashing is used instead)
# WARNING: changing this invalidates the existing vector index.
EMBEDDING_MODEL=

# Enrichment
WIKIPEDIA_RATE_LIMIT=0.5
DIFFBOT_API_KEY=
