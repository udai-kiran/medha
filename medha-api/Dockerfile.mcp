# syntax=docker/dockerfile:1.7
#
# Minimal image for the agent_mem MCP server (Streamable HTTP transport).
# Listens on MCP_PORT (default 3114).
# Run with: docker run -d -p 3114:3114 --env-file .env.mcp ghcr.io/udai-kiran/agent-mem-mcp:latest
# Configure Claude Code: claude mcp add agent-mem --transport http http://localhost:3114/mcp

ARG GO_VERSION=1.26.3

FROM golang:${GO_VERSION}-bookworm AS build
WORKDIR /src

COPY go.mod go.sum* ./
RUN go mod download

COPY . .
ARG VERSION=dev
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -trimpath -ldflags "-s -w -X main.Version=${VERSION}" \
    -o /out/agent-mem-mcp ./cmd/mcp

FROM gcr.io/distroless/static-debian12:nonroot AS runtime
WORKDIR /app
COPY --from=build /out/agent-mem-mcp /app/agent-mem-mcp

USER nonroot:nonroot
EXPOSE 3114
ENTRYPOINT ["/app/agent-mem-mcp"]
